<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import mazealgo.view.MazeDisplayer?>

<BorderPane fx:id="root" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mazealgo.view.MazeViewController"
            prefHeight="640.0" prefWidth="880.0"
            styleClass="root-pane">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="control-bar">
            <padding>
                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0"/>
            </padding>
            <Label text="Rows:"/>
            <Spinner fx:id="rowsSpinner" prefWidth="80.0" editable="true"/>
            <Label text="Cols:"/>
            <Spinner fx:id="colsSpinner" prefWidth="80.0" editable="true"/>
            <Button fx:id="generateButton" text="Generate" onAction="#onGenerate"
                    styleClass="primary-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="zoomLabel" text="Zoom 100%"/>
        </HBox>
    </top>

    <center>
        <Pane fx:id="mazeContainer" styleClass="maze-container">
            <MazeDisplayer fx:id="mazeDisplayer"/>
        </Pane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="status-bar">
            <padding>
                <Insets top="8.0" right="14.0" bottom="8.0" left="14.0"/>
            </padding>
            <Label fx:id="statusLabel"
                   text="Hit Generate to make a maze, then NumPad 1-9 to move. Ctrl + scroll to zoom."/>
        </HBox>
    </bottom>
</BorderPane>
