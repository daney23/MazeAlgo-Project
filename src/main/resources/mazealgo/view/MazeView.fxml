<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import mazealgo.view.MazeDisplayer?>
<?import mazealgo.view.Maze3DDisplayer?>

<BorderPane fx:id="root" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mazealgo.view.MazeViewController"
            prefHeight="680.0" prefWidth="1080.0"
            styleClass="root-pane">

    <top>
        <VBox styleClass="control-bar">
            <padding>
                <Insets top="8.0" right="14.0" bottom="8.0" left="14.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <fx:define>
                    <ToggleGroup fx:id="modeGroup"/>
                </fx:define>
                <ToggleButton fx:id="mode2DButton" text="2D" toggleGroup="$modeGroup"
                              selected="true" styleClass="mode-toggle"/>
                <ToggleButton fx:id="mode3DButton" text="3D" toggleGroup="$modeGroup"
                              styleClass="mode-toggle"/>
                <Separator orientation="VERTICAL"/>

                <Label text="Rows:"/>
                <Spinner fx:id="rowsSpinner" prefWidth="78.0" editable="true"/>
                <Label text="Cols:"/>
                <Spinner fx:id="colsSpinner" prefWidth="78.0" editable="true"/>
                <Label fx:id="depthLabel" text="Depth:"/>
                <Spinner fx:id="depthSpinner" prefWidth="78.0" editable="true"/>

                <Button fx:id="generateButton" text="Generate" onAction="#onGenerate"
                        styleClass="primary-button"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="nodesLabel" text="Nodes: 0" styleClass="metric-label"/>
                <Label fx:id="zoomLabel" text="Zoom 100%"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <padding>
                    <Insets top="8.0"/>
                </padding>
                <Label text="Algorithm:"/>
                <ComboBox fx:id="algorithmCombo" prefWidth="130.0"/>
                <Separator orientation="VERTICAL"/>
                <Button fx:id="hintButton" text="Solution Hint" onAction="#onSolutionHint"
                        styleClass="secondary-button"/>
                <Button fx:id="watchButton" text="Watch Search" onAction="#onWatchSearch"
                        styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="mazeContainer" styleClass="maze-container">
            <Pane fx:id="maze2DContainer">
                <MazeDisplayer fx:id="mazeDisplayer"/>
            </Pane>
            <Pane fx:id="maze3DContainer" visible="false">
                <Maze3DDisplayer fx:id="maze3DDisplayer"/>
            </Pane>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="status-bar">
            <padding>
                <Insets top="8.0" right="14.0" bottom="8.0" left="14.0"/>
            </padding>
            <Label fx:id="statusLabel"
                   text="Hit Generate to make a maze, then WASD or Arrow keys to move. Scroll to zoom."/>
        </HBox>
    </bottom>
</BorderPane>
